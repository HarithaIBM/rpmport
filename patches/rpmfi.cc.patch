+#ifdef __MVS__
+mode_t zos_normalize_mode(mode_t raw)
+{
+    mode_t perms = raw & 0x0FFF;     /* keep only permission bits */
+    mode_t ztype = raw & 0xFF000000; /* z/OS type bits */
+
+    mode_t type;
+    switch (ztype) {
+        case 0x01000000: type = S_IFIFO;  break;
+        case 0x02000000: type = S_IFCHR;  break;
+        case 0x03000000: type = S_IFREG;  break;
+        case 0x04000000: type = S_IFDIR;  break;
+        case 0x05000000: type = S_IFBLK;  break;
+        case 0x06000000: type = S_IFLNK;  break;
+        case 0x07000000: type = S_IFSOCK; break;
+        default:         type = S_IFREG;  break; /* assume regular */
+    }
 
+    printf("zos_normalize_mode: raw=0x%08x ztype=0x%08x -> type=0x%05o perms=0%04o\n",
+           raw, ztype, type, perms);
+
+    return type | perms;
+}
+#endif
