+#ifdef __MVS__
+static mode_t zos_mode_normalize(mode_t zos_mode)
+{
+	    mode_t perms = zos_mode & 07777;
+	        mode_t zos_ftype = zos_mode & S_IFMT;   /* <-- fixed */
+
+		    mode_t posix_ftype;
+		        switch (zos_ftype) {
+				        case 0300000000:   /* z/OS regular file */
+						            posix_ftype = S_IFREG;   /* 0100000 */
+							                break;
+									        case S_IFDIR:
+									        case S_IFLNK:
+									        case S_IFIFO:
+									        case S_IFCHR:
+									        case S_IFBLK:
+									        case S_IFSOCK:
+									            posix_ftype = zos_ftype;
+										                break;
+												        default:
+												            fprintf(stderr, "DEBUG: zos_mode_normalize: unknown ftype %o, defaulting to REG\n", zos_ftype);
+													                posix_ftype = S_IFREG;
+															            break;
+																        }
+
+			    return posix_ftype | perms;
+}
+#endif
