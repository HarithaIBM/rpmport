 if (NOT MAJOR_IN_SYSMACROS)
@@ -553,7 +574,7 @@ install(FILES
 	DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/rpm
 )
 
-export(TARGETS librpm librpmio librpmbuild librpmsign
+export(TARGETS librpm rpmio librpmbuild librpmsign
